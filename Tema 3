\section{Exercițiul 2: Algoritmul de factorizare al lui Fermat}

\begin{lstlisting}
import math

def factorizare_fermat(n):

    if n % 2 == 0:
        return (2, n // 2)
    
    x = math.isqrt(n)
    if x * x == n:
        return (x, x)
    
    x += 1
    while True:
        y2 = x * x - n
        y = math.isqrt(y2)
        
        if y * y == y2:
            # Am gasit o factorizare
            return (x - y, x + y)
        
        x += 1
        
        if x > (n + 1) // 2:
            return (n, 1)  # n este prim

def factorizare_fermat_completa(n):

    factori = []
    numar = n
    
    while numar > 1:
        if numar % 2 == 0:
            factori.append(2)
            numar //= 2
            continue
        
        a, b = factorizare_fermat(numar)
        
        if b == 1: 
            factori.append(a)
            break
        else:
            factori.append(a)
            numar = b
    
    return sorted(factori)

\end{lstlisting}

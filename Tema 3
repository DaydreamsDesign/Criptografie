\section{Exercițiul 1: Algoritmul Solovay-Strasen}

\begin{lstlisting}
import random

def cmmdc(a, b):
    while b:
        a, b = b, a % b
    return a

def putere_modulo(baza, exponent, mod):
    rezultat = 1
    baza = baza % mod
    while exponent > 0:
        if exponent & 1:
            rezultat = (rezultat * baza) % mod
        baza = (baza * baza) % mod
        exponent >>= 1
    return rezultat

def simbol_jacobi(a, n):
    if n <= 0 or n % 2 == 0:
        return 0
    
    rez = 1
    a = a % n
    
    while a != 0:
        while a % 2 == 0:
            a //= 2
            if n % 8 == 3 or n % 8 == 5:
                rez = -rez
        
        a, n = n, a
        if a % 4 == 3 and n % 4 == 3:
            rez = -rez
        a = a % n
    
    return rez if n == 1 else 0

def test_solovay_strassen(n, k=5):

    if n < 2:
        return False, 0
    if n == 2:
        return True, 1
    if n % 2 == 0:
        return False, 0
    
    for i in range(k):
        a = random.randint(2, n - 2)

        if cmmdc(a, n) != 1:
            return False, 0
        
        j = simbol_jacobi(a, n)

        exp = (n - 1) // 2
        p = putere_modulo(a, exp, n)
        
        if p != j % n:
            return False, 0

    prob = 1 - (0.5) ** k
    return True, prob


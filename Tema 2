\section*{Exercițiul 5}

\begin{align*}
67890 &= 9876 \times 6 + 8634 \\
9876 &= 8634 \times 1 + 1242 \\
8634 &= 1242 \times 6 + 1182 \\
1242 &= 1182 \times 1 + 60 \\
1182 &= 60 \times 19 + 42 \\
60 &= 42 \times 1 + 18 \\
42 &= 18 \times 2 + 6 \\
18 &= 6 \times 3 + 0
\end{align*}

$$\Rightarrow (67890, 9876) = 6$$

$$x_{67890} = (1, 0), \quad x_{9876} = (0, 1)$$

$$67890 = 9876 \times 6 + 8634$$

$$ x_{8634} = (1, 0) - 6(0, 1) = (1, -6) $$

$$9876 = 8634 \times 1 + 1242$$
$$ x_{1242} = (0, 1) - 1(1, -6) = (-1, 7) $$ 
$$8634 = 1242 \times 6 + 1182$$
$$ x_{1182} = (1, -6) - 6(-1, 7) = (7, -48)$$ 
$$1242 = 1182 \times 1 + 60$$
$$ x_{60} = (-1, 7) - 1(7, -48) = (-8, 55)$$ 
$$1182 = 60 \times 19 + 42$$
$$ x_{42} = (7, -48) - 19(-8, 55) = (159, -1093)$$ 
$$60 = 42 \times 1 + 18$$
$$ x_{18} = (-8, 55) - 1(159, -1093) = (-167, 1148)$$ 
$$42 = 18 \times 2 + 6$$
$$ x_{6} = (159, -1093) - 2(-167, 1148) = (493, -3389)$$ 
$$18 = 6 \times 3 + 0$$
$$
\boxed{6 = 493 \times 67890 + (-3389) \times 9876}
$$

\section*{Exercițiul 6}

Determinăm \(29^{-1} \pmod{31}\).
$$
(29, 31) = 1 \quad \text{(numere prime între ele)} \Rightarrow \text{inversul există}
$$

\begin{align*}
31 &= 29 \times 1 + 2 \\
29 &= 2 \times 14 + 1 \\
2 &= 1 \times 2 + 0
\end{align*}
$$
\Rightarrow (31, 29) = 1
$$

$$
x_{31} = (1, 0), \quad x_{29} = (0, 1)
$$
$$31 = 29 \times 1 + 2$$
$$
x_2 = (1, 0) - 1(0, 1) = (1, -1)
$$

$$29 = 2 \times 14 + 1$$
$$
x_1 = (0, 1) - 14(1, -1) = (-14, 15)
$$

$$2 = 1 \times 2 + 0$$

Obținem:
$$
1 = (-14) \times 31 + 15 \times 29
$$

Reducem relația modulo 31:
$$
15 \times 29 \equiv 1 \pmod{31}
$$

$$
\boxed{29^{-1} \equiv 15 \pmod{31}}
$$


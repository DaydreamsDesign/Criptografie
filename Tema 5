def mod_invers(a, m):
    a = a % m
    for x in range(1, m):
        if (a * x) % m == 1:
            return x
    return None

def euclid_extins(a, b):
    if a == 0:
        return b, 0, 1
    gcd, x1, y1 = euclid_extins(b % a, a)
    x = y1 - (b // a) * x1
    y = x1
    return gcd, x, y

def mod_invers_extins(a, m):
    gcd, x, y = euclid_extins(a, m)
    if gcd != 1:
        return None
    return x % m


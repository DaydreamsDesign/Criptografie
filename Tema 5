def decriptare_afin_blocuri(text_criptat, a, b, alfabet):
   
    n = len(alfabet)
    n2 = n * n
    
    a_inv = mod_invers_extins(a, n2)
    if a_inv is None:
        raise ValueError(f"a={a} nu este inversabil modulo {n2}")
    
    text_decriptat = []
    
    for i in range(0, len(text_criptat), 2):
        if i + 1 < len(text_criptat):
            ch1 = text_criptat[i]
            ch2 = text_criptat[i + 1]
            
            idx1 = char_index(ch1, alfabet)
            idx2 = char_index(ch2, alfabet)
            
            valoare_bloc = idx1 * n + idx2
            valoare_decriptata = ((valoare_bloc - b) * a_inv) % n2
            
            idx1_decriptat = valoare_decriptata // n
            idx2_decriptat = valoare_decriptata % n
            
            text_decriptat.append(index_char(idx1_decriptat, alfabet))
            text_decriptat.append(index_char(idx2_decriptat, alfabet))
        else:
            text_decriptat.append(text_criptat[i])
    
    return ''.join(text_decriptat)

def decriptare_vigenere(text_criptat, cheie, alfabet):
    n = len(alfabet)
    text_decriptat = []
    
    cheie_extinsa = ''
    j = 0
    for i in range(len(text_criptat)):
        if text_criptat[i] in alfabet:
            cheie_extinsa += cheie[j % len(cheie)]
            j += 1
        else:
            cheie_extinsa += text_criptat[i] 
    j = 0
    for i in range(len(text_criptat)):
        char_criptat = text_criptat[i]
        
        if char_criptat in alfabet:
            idx_c = char_index(char_criptat, alfabet)
            idx_k = char_index(cheie_extinsa[i], alfabet)
            
            idx_p = (idx_c - idx_k) % n
            
            text_decriptat.append(index_char(idx_p, alfabet))
        else:
            text_decriptat.append(char_criptat)
    
    return ''.join(text_decriptat)


